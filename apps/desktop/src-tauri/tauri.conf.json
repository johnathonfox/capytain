{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Capytain",
  "version": "0.0.0",
  "identifier": "app.capytain.desktop",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Capytain",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "Copyright (c) Capytain Contributors",
    "shortDescription": "Capytain — a Rust-native desktop email client.",
    "longDescription": "Capytain is an experimental desktop email client written end-to-end in Rust. Phase 0 scaffolding.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
