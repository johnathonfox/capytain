{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QSL",
  "version": "0.0.1",
  "identifier": "app.qsl.desktop",
  "build": {
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QSL",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "copyright": "Copyright (c) QSL Contributors",
    "shortDescription": "QSL — a Rust-native desktop email client.",
    "longDescription": "QSL is an experimental desktop email client written end-to-end in Rust. Phase 0 scaffolding.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mailto"]
      }
    }
  }
}
