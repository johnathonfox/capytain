# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Build artifacts
/dist
/out

# Tauri build-script output. `tauri-build` regenerates these on every
# `cargo check` from `tauri.conf.json` and the capability files —
# they are not source.
apps/desktop/src-tauri/gen/
apps/desktop/ui/dist/

# Claude Code session state — runtime lock + scheduled-task ledger.
# Committed once by mistake; pinning here so it can't slip back in.
# Ignore everything under .claude/ EXCEPT shared agent definitions
# (project-level prompts that teammates and worktrees should pick up).
.claude/*
!.claude/agents/

# Local env
.env
.env.local

# Local debug log emitted by ad-hoc `cargo run -p qsl-desktop > qsl-launch.log`
# launches.
qsl-launch.log
